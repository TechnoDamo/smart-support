# Общие креды инфраструктуры
POSTGRES_USER=smart
POSTGRES_PASSWORD=smart
POSTGRES_DB=smart
POSTGRES_PORT=5432
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# Object storage
OBJECT_STORAGE_LOCAL_PATH=/app/storage
MINIO_ROOT_USER=smart
MINIO_ROOT_PASSWORD=smartminio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=smart-support
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Backend
APP_ENV=dev
APP_PORT=8081
CHANNEL_TELEGRAM_PROVIDER=mock
TELEGRAM_BOT_TOKEN=
PROMPTS_DIR=/app/prompts

# Облачный OpenAI-совместимый провайдер
OPENAI_API_KEY=
LLM_API_KEY=
EMBEDDING_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
EMBEDDING_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VECTOR_SIZE=1536

# Локальный embedding (vLLM)
EMBEDDING_PORT=8090
EMBEDDING_MAX_MODEL_LEN=512
HUGGING_FACE_HUB_TOKEN=

# Локальный LLM (llama.cpp)
LLM_PORT=8091
LLM_CTX_SIZE=4096
LLM_N_GPU_LAYERS=0
LLM_THREADS=8
LLM_BATCH=512
LLM_MODEL=/models/Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLM_MODELS_DIR=./models
