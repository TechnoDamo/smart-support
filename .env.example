# Единый env-файл всего проекта.
# Скопируйте этот файл в `.env` в корне репозитория и правьте только его.

# ─── Инфраструктура ─────────────────────────────────────────────────────────
POSTGRES_USER=smart
POSTGRES_PASSWORD=smart
POSTGRES_DB=smart
POSTGRES_PORT=5432

QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

MINIO_ROOT_USER=smart
MINIO_ROOT_PASSWORD=smartminio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Основные параметры backend ─────────────────────────────────────────────
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8081
LOG_LEVEL=INFO
LOG_FORMAT=text

# CORS можно передавать как CSV:
#   http://127.0.0.1:3000,http://localhost:3000
# или как JSON-массив:
#   ["http://127.0.0.1:3000","http://localhost:3000"]
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX=

# ─── Graylog Logging ────────────────────────────────────────────────────────
# Для Docker-стека с `make up ... GRAYLOG=true` используйте `graylog`.
# Для локального backend вне Docker используйте `localhost`.
GRAYLOG_ENABLED=false
GRAYLOG_HOST=graylog
GRAYLOG_PORT=12201
GRAYLOG_PROTOCOL=tcp
GRAYLOG_ADMIN_PASSWORD=admin

# ─── База данных ────────────────────────────────────────────────────────────
# Для локального backend без Docker допускается SQLite:
#   sqlite+aiosqlite:///./smart_support.db
# Для Postgres из compose-стека:
#   postgresql+asyncpg://smart:smart@localhost:5432/smart
DATABASE_URL=postgresql+asyncpg://smart:smart@localhost:5432/smart

# ─── Провайдер LLM ──────────────────────────────────────────────────────────
# LLM_PROVIDER: openai_compatible | mock
# Если один облачный ключ используется и для LLM, и для embeddings,
# можно заполнить только OPENAI_API_KEY, а отдельные *_API_KEY оставить пустыми.
OPENAI_API_KEY=
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2

# ─── Провайдер Embeddings ───────────────────────────────────────────────────
# EMBEDDING_PROVIDER: openai_compatible | mock
EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VECTOR_SIZE=1536
EMBEDDING_DISTANCE_METRIC=cosine

# ─── Векторное хранилище ────────────────────────────────────────────────────
# VECTOR_STORE_PROVIDER: qdrant | mock
VECTOR_STORE_PROVIDER=mock
QDRANT_URL=http://localhost:6333

# ─── Object storage ─────────────────────────────────────────────────────────
# OBJECT_STORAGE_PROVIDER: s3 | local
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_LOCAL_PATH=./storage
S3_BUCKET=smart-support
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Telegram ───────────────────────────────────────────────────────────────
# CHANNEL_TELEGRAM_PROVIDER: telegram | mock
CHANNEL_TELEGRAM_PROVIDER=mock
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_LIMIT=50
TELEGRAM_POLLING_TIMEOUT_SECONDS=0
TELEGRAM_POLLING_REQUEST_TIMEOUT_SECONDS=35
SCHEDULER_TELEGRAM_POLLING_INTERVAL_SECONDS=5

# ─── Поведение ──────────────────────────────────────────────────────────────
DEFAULT_CHAT_MODE=ai_assist
TICKET_INACTIVITY_TIMEOUT_MINUTES=60

OUTBOX_MAX_RETRIES=5
OUTBOX_RETRY_INTERVAL_SECONDS=30

RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_MIN_SCORE=0.2
RAG_CHUNK_SIZE_TOKENS=400
RAG_CHUNK_OVERLAP_TOKENS=60
RAG_INGESTION_MAX_RETRIES=3
RAG_INGESTION_JOB_TIMEOUT_SECONDS=120
RAG_INGESTION_WORKER_BATCH_SIZE=10
RAG_HYBRID_DENSE_WEIGHT=0.7
RAG_HYBRID_SPARSE_WEIGHT=0.3

SCHEDULER_TICKET_CLOSE_INTERVAL_SECONDS=60
SCHEDULER_OUTBOX_INTERVAL_SECONDS=10
SCHEDULER_INGESTION_RETRY_INTERVAL_SECONDS=120

PROMPTS_DIR=./prompts

# ─── Локальный embedding (vLLM) ─────────────────────────────────────────────
EMBEDDING_PORT=8090
EMBEDDING_MAX_MODEL_LEN=512
HUGGING_FACE_HUB_TOKEN=

# ─── Локальный LLM (llama.cpp) ──────────────────────────────────────────────
LLM_PORT=8091
LLM_CTX_SIZE=4096
LLM_N_GPU_LAYERS=0
LLM_THREADS=8
LLM_BATCH=512
LLM_MODELS_DIR=./models
