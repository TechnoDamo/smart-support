# Единый env-файл всего проекта.
# Скопируйте в `.env` в корне репозитория и заполните своими значениями.

# ─── Основные параметры ──────────────────────────────────────────────────────
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8081
LOG_LEVEL=INFO
LOG_FORMAT=text
DOCKER_PLATFORM=linux/amd64
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX=

# ─── База данных (Реляционная) ───────────────────────────────────────────────
POSTGRES_USER=smart
POSTGRES_PASSWORD=smart
POSTGRES_DB=smart_support_db
POSTGRES_PORT=5432
# Для локального запуска backend вне Docker (make up подставляет свой URL автоматически):
DATABASE_URL=postgresql+asyncpg://smart:smart@localhost:5432/smart_support_db

# ─── База данных (Векторная) ─────────────────────────────────────────────────
VECTOR_STORE_PROVIDER=qdrant
QDRANT_IMAGE=qdrant/qdrant:v1.12.0
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── База данных (Объектная) ─────────────────────────────────────────────────
OBJECT_STORAGE_PROVIDER=local
S3_BUCKET=smart-support
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MINIO_ROOT_USER=smart
MINIO_ROOT_PASSWORD=smartminio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Сервис LLM ──────────────────────────────────────────────────────────────
# Локальный сервер (llama.cpp) — активен при AI=local-llm / AI=local-ai
LLM_MODELS_DIR=./models
LLM_PORT=8091
LLM_CTX_SIZE=4096
LLM_N_GPU_LAYERS=0
LLM_THREADS=8
LLM_BATCH=512
# Провайдер (openai_compatible | mock)
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2

# ─── Сервис Embeddings ───────────────────────────────────────────────────────
# Локальный сервер (TEI) — активен при AI=local-embedding / AI=local-ai
# CPU:             ghcr.io/huggingface/text-embeddings-inference:cpu-1.5
# GPU (T4):        ghcr.io/huggingface/text-embeddings-inference:turing-1.5
# GPU (A100/H100): ghcr.io/huggingface/text-embeddings-inference:89-1.5
TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-1.5
EMBEDDING_MODEL_STORAGE_FOLDER=.data
EMBEDDING_PORT=8090
HUGGING_FACE_HUB_TOKEN=
HF_ENDPOINT=https://huggingface.co
# Провайдер (openai_compatible | mock)
EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VECTOR_SIZE=1536
EMBEDDING_DISTANCE_METRIC=cosine

# ─── Telegram ────────────────────────────────────────────────────────────────
# CHANNEL_TELEGRAM_PROVIDER: telegram | mock
CHANNEL_TELEGRAM_PROVIDER=mock
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_LIMIT=50
TELEGRAM_POLLING_TIMEOUT_SECONDS=0
TELEGRAM_POLLING_REQUEST_TIMEOUT_SECONDS=35
SCHEDULER_TELEGRAM_POLLING_INTERVAL_SECONDS=5

# ─── Graylog ─────────────────────────────────────────────────────────────────
GRAYLOG_ENABLED=false
GRAYLOG_HOST=localhost
GRAYLOG_PORT=12201
GRAYLOG_PROTOCOL=tcp
GRAYLOG_ADMIN_PASSWORD=admin

# ─── RAG ─────────────────────────────────────────────────────────────────────
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_MIN_SCORE=0.2
RAG_CHUNK_SIZE_TOKENS=400
RAG_CHUNK_OVERLAP_TOKENS=60
RAG_INGESTION_MAX_RETRIES=3
RAG_INGESTION_JOB_TIMEOUT_SECONDS=120
RAG_INGESTION_WORKER_BATCH_SIZE=10
RAG_HYBRID_DENSE_WEIGHT=0.7
RAG_HYBRID_SPARSE_WEIGHT=0.3

# ─── Поведение системы ───────────────────────────────────────────────────────
DEFAULT_CHAT_MODE=ai_assist
TICKET_INACTIVITY_TIMEOUT_MINUTES=60
OUTBOX_MAX_RETRIES=5
OUTBOX_RETRY_INTERVAL_SECONDS=30
SCHEDULER_TICKET_CLOSE_INTERVAL_SECONDS=60
SCHEDULER_OUTBOX_INTERVAL_SECONDS=10
SCHEDULER_INGESTION_RETRY_INTERVAL_SECONDS=120
PROMPTS_DIR=./prompts
